@model WebApplication1.Models.FlightSearchResult
@{
    ViewData["Title"] = "Search Results";
}

<style>
    .results-banner {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
        color: #fff;
        padding: 28px 0;
        margin: -24px -12px 28px;
    }
    .summary-bar {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
        padding: 16px 24px;
        margin-bottom: 24px;
        display: flex;
        flex-wrap: wrap;
        gap: 24px;
        align-items: center;
    }
    .summary-item { font-size: 14px; }
    .summary-item small { display: block; color: #64748b; font-size: 11px; }
    .summary-item strong { color: #0f172a; }
    .flight-card {
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        background: #fff;
        margin-bottom: 16px;
        transition: .2s;
        overflow: hidden;
    }
    .flight-card:hover {
        border-color: #93c5fd;
        box-shadow: 0 4px 16px rgba(37,99,235,.1);
    }
    .flight-card-body { padding: 20px 24px; }
    .airline-logo {
        width: 42px; height: 42px;
        border-radius: 50%;
        background: #1e3a5f;
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 14px;
    }
    .time-display { font-size: 22px; font-weight: 700; color: #0f172a; }
    .city-label { font-size: 12px; color: #64748b; }
    .route-line {
        flex: 1;
        text-align: center;
        position: relative;
        padding: 0 8px;
    }
    .route-line::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 12px;
        right: 12px;
        height: 1px;
        background: #cbd5e1;
    }
    .route-line span {
        position: relative;
        z-index: 1;
        background: #fff;
        padding: 2px 8px;
        font-size: 11px;
        color: #64748b;
    }
    .badge-economy { background: #dbeafe; color: #1e40af; }
    .badge-business { background: #fef3c7; color: #92400e; }
    .badge-first { background: #ede9fe; color: #5b21b6; }
    .price-tag { font-size: 24px; font-weight: 700; color: #2563eb; }
    .btn-details {
        background: #2563eb;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        font-size: 13px;
        padding: 8px 20px;
    }
    .btn-details:hover { background: #1d4ed8; }
    .sort-bar {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.05);
        padding: 12px 20px;
        margin-bottom: 20px;
    }
    .no-results { text-align: center; padding: 60px 20px; color: #64748b; }
</style>

<div class="results-banner">
    <div class="container">
        <h1 class="h4 mb-0"><i class="bi bi-airplane me-2"></i>Flight Results</h1>
    </div>
</div>

<div class="container">
    <div class="summary-bar">
        <div class="summary-item">
            <small>From</small>
            <strong>@Model.SearchCriteria.DepartureCity</strong>
        </div>
        <div class="summary-item">
            <i class="bi bi-arrow-right text-muted"></i>
        </div>
        <div class="summary-item">
            <small>To</small>
            <strong>@Model.SearchCriteria.ArrivalCity</strong>
        </div>
        <div class="summary-item">
            <small>Date</small>
            <strong>@Model.SearchCriteria.TravelDate.ToString("dd MMM yyyy")</strong>
        </div>
        <div class="summary-item">
            <small>Passengers</small>
            <strong>@Model.SearchCriteria.NumberOfPassengers</strong>
        </div>
        @if (Model.SearchCriteria.ClassType != "All")
        {
            <div class="summary-item">
                <small>Class</small>
                <strong>@Model.SearchCriteria.ClassType</strong>
            </div>
        }
        <div class="ms-auto">
            <a asp-action="Search" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-pencil-square"></i> Modify
            </a>
        </div>
    </div>

    <div class="sort-bar d-flex flex-wrap align-items-center justify-content-between gap-2">
        <span class="fw-semibold">
            @Model.TotalResults flight@(Model.TotalResults != 1 ? "s" : "") found
        </span>
        @if (Model.TotalResults > 0)
        {
            <form asp-action="SortResults" method="post" class="d-flex align-items-center gap-2">
                <input type="hidden" asp-for="SearchCriteria.DepartureCity" />
                <input type="hidden" asp-for="SearchCriteria.ArrivalCity" />
                <input type="hidden" asp-for="SearchCriteria.TravelDate" />
                <input type="hidden" asp-for="SearchCriteria.NumberOfPassengers" />
                <input type="hidden" asp-for="SearchCriteria.ClassType" />
                <label class="mb-0 text-muted small">Sort by</label>
                <select name="sortBy" class="form-select form-select-sm" style="width:180px" onchange="this.form.submit()">
                    <option value="">Relevance</option>
                    <option value="Price">Price – Low to High</option>
                    <option value="Duration">Duration – Shortest</option>
                </select>
            </form>
        }
    </div>

    @if (Model.TotalResults == 0)
    {
        <div class="no-results">
            <i class="bi bi-emoji-frown" style="font-size: 3rem;"></i>
            <h5 class="mt-3">No flights found</h5>
            <p>Try different dates or destinations.</p>
            <a asp-action="Search" class="btn btn-primary">Search Again</a>
        </div>
    }
    else
    {
        foreach (var flight in Model.Flights)
        {
            var badgeClass = flight.ClassType switch
            {
                "Economy" => "badge-economy",
                "Business" => "badge-business",
                _ => "badge-first"
            };

            <div class="flight-card">
                <div class="flight-card-body">
                    <div class="row align-items-center">
                        <div class="col-lg-2 col-md-3 mb-2 mb-md-0">
                            <div class="d-flex align-items-center gap-2">
                                <div class="airline-logo">@flight.AirlineName[..2].ToUpper()</div>
                                <div>
                                    <div class="fw-semibold" style="font-size:14px">@flight.AirlineName</div>
                                    <small class="text-muted">@flight.FlightNumber</small>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-5 col-md-4 mb-2 mb-md-0">
                            <div class="d-flex align-items-center">
                                <div class="text-center">
                                    <div class="time-display">@flight.DepartureDateTime.ToString("HH:mm")</div>
                                    <div class="city-label">@flight.DepartureCity</div>
                                </div>
                                <div class="route-line">
                                    <span>@flight.DurationInHours.ToString("0.0")h</span>
                                </div>
                                <div class="text-center">
                                    <div class="time-display">@flight.ArrivalDateTime.ToString("HH:mm")</div>
                                    <div class="city-label">@flight.ArrivalCity</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-2 col-md-2 mb-2 mb-md-0 text-center">
                            <span class="badge @badgeClass rounded-pill px-3 py-1">@flight.ClassType</span>
                            <div class="mt-1">
                                @if (flight.AvailableSeats < 10)
                                {
                                    <small class="text-danger fw-semibold">@flight.AvailableSeats left!</small>
                                }
                                else
                                {
                                    <small class="text-muted">@flight.AvailableSeats seats</small>
                                }
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-3 text-md-end text-center">
                            <div class="price-tag">₹@flight.Price.ToString("N0")</div>
                            <small class="text-muted d-block mb-2">per person</small>
                            <a asp-action="Details" asp-route-id="@flight.FlightId" class="btn btn-primary btn-details">
                                View Details <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="text-center mt-4 mb-5">
            <a asp-action="Search" class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left me-1"></i> New Search
            </a>
        </div>
    }
</div>
